From 8ee1f73da570903e3bfed3d55e5453620e9489ff Mon Sep 17 00:00:00 2001
From: Isaac <isaac@arbor>
Date: Thu, 9 Apr 2026 17:55:06 +0000
Subject: [PATCH] Fix SAFE verdicts, wire external links, show verdict
 reasoning in UI
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- Remove blanket resolutionSourceMatch downgrade for non-economic markets
  Awards, sports, political deadlines now keep SAFE verdict when resolution
  source isn't explicitly stated — only economic reports (CPI/FOMC/jobs)
  get downgraded to CAUTION for source mismatch
- Update Claude prompt: C2 clarifies unique vs recurring event close-date gaps,
  C6 now tells Claude to set resolution_source_match=true for awards/sports/politics
- Wire Polymarket and Kalshi links to real URLs (polyMarket.url / kalshiMarket.url)
- Add verdict reasoning panel to expanded opportunity row
- Pass kalshiYesMeaning + polyHedgeOutcomeLabel to frontend
- Update ArbitrageOpportunity type and Opportunity interface
---
 src/data/mock.ts                    |  8 ++++++
 src/pages/Opportunities.tsx         | 37 +++++++++++++++++++++++--
 src/types/index.ts                  |  3 ++
 supabase/functions/scanner/index.ts | 43 ++++++++++++++++++++++-------
 4 files changed, 79 insertions(+), 12 deletions(-)

diff --git a/src/data/mock.ts b/src/data/mock.ts
index 5e00758..4733be1 100644
--- a/src/data/mock.ts
+++ b/src/data/mock.ts
@@ -43,6 +43,14 @@ export interface Opportunity {
   effectiveCloseDate?: string;
   kalshiCloseDate?: string;
   polyCloseDate?: string;
+  // Live URLs for direct platform links.
+  polyUrl?: string;
+  kalshiUrl?: string;
+  // Claude verification output — shown in expanded row.
+  verdictReasoning?: string;
+  riskFactors?: string[];
+  kalshiYesMeaning?: string;
+  polyHedgeOutcomeLabel?: string;
 }
 
 export const opportunities: Opportunity[] = [
